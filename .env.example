# Copy this file to `.env` and fill in the real values. `.env` is gitignored.
# Loaded by run.sh / run.cmd before starting the backend.

# ---- Brevo (transactional email) ----
# Brevo dashboard → SMTP & API → API Keys → create a v3 API key.
BREVO_API_KEY=

# Must be a sender you have verified in Brevo (Senders & IPs → Senders).
# Brevo rejects sends from unverified from-addresses.
EMAIL_FROM=no-reply@campusconnect.io
EMAIL_FROM_NAME=CampusConnect Placements

# ---- Database (Supabase Postgres) ----
DATABASE_PASSWORD=

# ---- AI assistant (OpenRouter) ----
# Set enabled=true and provide a key + model to turn on the inline text tools and chatbot.
# Get a key at https://openrouter.ai/keys. Model examples: google/gemini-2.0-flash-001,
# openai/gpt-4o-mini, or a free tier like google/gemma-4-31b-it:free.
AI_ENABLED=false
AI_API_KEY=
AI_MODEL=

# ---- Bootstrap admin (seeded by Flyway V3 on first migrate) ----
# The first admin account. There is no admin self-signup, so this seed is the
# only way to get one. Override before running against a real database.
ADMIN_EMAIL=admin@campusconnect.io
ADMIN_PASSWORD=Admin@12345
