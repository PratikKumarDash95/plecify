# Copy to .env and adjust. In dev the value is a relative path proxied to :8080.
# In production point this at the deployed API origin, e.g. https://api.example.com/api/v1
VITE_API_BASE_URL=/api/v1

# Google OAuth web client id (Google Cloud Console → Credentials → OAuth 2.0 Client IDs).
# Must match app.oauth.google.client-id on the backend. Leave blank to hide the Google button.
VITE_GOOGLE_CLIENT_ID=
